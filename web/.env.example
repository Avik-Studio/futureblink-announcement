# ----- MongoDB (required) -----
# Local:  mongodb://127.0.0.1:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=
MONGODB_DB=futureblink_shopify

# ----- Shopify -----
# During local development (`npm run dev`) the Shopify CLI injects SHOPIFY_API_KEY,
# SHOPIFY_API_SECRET, SCOPES and HOST automatically, so you can leave these blank.
#
# For a PRODUCTION deployment (Render/Heroku/etc.) set them from your app's
# "API credentials" in the Partner dashboard:
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,write_themes
HOST=
PORT=3000
